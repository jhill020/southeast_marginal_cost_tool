.ruff_cache/

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# IDEs
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Raw large dataset folders (ignore contents except instructions.txt)
Cambium_Hourly_Data_raw/*
